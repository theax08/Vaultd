{%- style -%}
  .countdown-block-{{ block.id }} {
    display: block;
    width: 100%;
  }

  .countdown-section-{{ block.id }} {
    width: 100%;
    padding: 32px 24px;
    box-sizing: border-box;
  }

  .countdown-card-{{ block.id }} {
    box-sizing: border-box;
    width: 100%;
    max-width: 560px;
    margin: 0 auto;
    text-align: center;
    border-radius: 16px;
    padding: 32px 28px;
  }

  /* Design 1: Minimal / Elegant */
  .countdown-card-{{ block.id }}.is-minimal {
    background: rgb(var(--color-background));
    border: 1px solid rgba(var(--color-foreground), 0.12);
  }

  /* Design 2: Bold / Vibrant (gradient, 2 color variants) */
  .countdown-card-{{ block.id }}.is-bold {
    color: #ffffff;
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.18);
  }
  .countdown-card-{{ block.id }}.is-bold.is-purple {
    background: linear-gradient(135deg, #6d5bd0 0%, #8b3fd1 100%);
  }
  .countdown-card-{{ block.id }}.is-bold.is-red {
    background: linear-gradient(135deg, #d04b4b 0%, #c13fb0 100%);
  }

  /* Design 3: Glassmorphism */
  .countdown-card-{{ block.id }}.is-glass {
    background: rgba(255, 255, 255, 0.55);
    border: 1px solid rgba(255, 255, 255, 0.6);
    box-shadow: 0 8px 32px rgba(31, 38, 135, 0.1);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
  }

  .countdown-eyebrow-{{ block.id }} {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin: 0 0 16px 0;
    opacity: 0.75;
  }

  .countdown-timer-{{ block.id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
  }

  .countdown-unit-{{ block.id }} {
    min-width: 80px;
    border-radius: 10px;
    padding: 14px 12px;
  }

  .countdown-card-{{ block.id }}.is-minimal .countdown-unit-{{ block.id }} {
    background: rgba(var(--color-foreground), 0.05);
  }
  .countdown-card-{{ block.id }}.is-bold .countdown-unit-{{ block.id }} {
    background: rgba(255, 255, 255, 0.15);
  }
  .countdown-card-{{ block.id }}.is-glass .countdown-unit-{{ block.id }} {
    background: rgba(255, 255, 255, 0.5);
  }

  .countdown-value-{{ block.id }} {
    font-size: 36px;
    font-weight: 800;
    line-height: 1.1;
    display: block;
  }

  .countdown-label-{{ block.id }} {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    opacity: 0.65;
    display: block;
    margin-top: 2px;
  }

  .countdown-sep-{{ block.id }} {
    font-size: 18px;
    font-weight: 700;
    opacity: 0.4;
  }

  .countdown-footer-{{ block.id }} {
    margin: 16px 0 0 0;
    font-size: 13px;
    opacity: 0.8;
  }

  .countdown-card-{{ block.id }}[hidden] {
    display: none;
  }
{%- endstyle -%}

<div class="countdown-block countdown-block-{{ block.id }}">
  <div class="countdown-section-{{ block.id }}">
    <div
      id="countdown-card-{{ block.id }}"
      class="countdown-card-{{ block.id }} is-{{ block.settings.design }} is-{{ block.settings.bold_color }}"
    >
      <p class="countdown-eyebrow-{{ block.id }}">
        {% if block.settings.design == "glass" %}
          {{ block.settings.eyebrow_glass }}
        {% else %}
          {{ block.settings.eyebrow }}
        {% endif %}
      </p>

      <div class="countdown-timer-{{ block.id }}">
        <div class="countdown-unit-{{ block.id }}">
          <span class="countdown-value-{{ block.id }}" data-countdown-days>00</span>
          <span class="countdown-label-{{ block.id }}">Days</span>
        </div>
        <span class="countdown-sep-{{ block.id }}">:</span>
        <div class="countdown-unit-{{ block.id }}">
          <span class="countdown-value-{{ block.id }}" data-countdown-hours>00</span>
          <span class="countdown-label-{{ block.id }}">Hours</span>
        </div>
        <span class="countdown-sep-{{ block.id }}">:</span>
        <div class="countdown-unit-{{ block.id }}">
          <span class="countdown-value-{{ block.id }}" data-countdown-min>00</span>
          <span class="countdown-label-{{ block.id }}">Min</span>
        </div>
      </div>

      <p class="countdown-footer-{{ block.id }}">
        {% if block.settings.design == "minimal" %}
          <span data-countdown-dropname>{{ block.settings.fallback_drop_name }}</span>
        {% elsif block.settings.design == "bold" %}
          {{ block.settings.footer_bold }}
        {% else %}
          {{ block.settings.footer_glass }}
        {% endif %}
      </p>
    </div>
  </div>
</div>

<script>
  (function() {
    const id = '{{ block.id }}';
    const card = document.getElementById('countdown-card-' + id);
    if (!card) return;

    const daysEl = card.querySelector('[data-countdown-days]');
    const hoursEl = card.querySelector('[data-countdown-hours]');
    const minEl = card.querySelector('[data-countdown-min]');
    const dropNameEl = card.querySelector('[data-countdown-dropname]');

    const staticDropId = '{{ block.settings.drop_id | escape }}';
    let targetTime = null;
    let intervalId = null;

    function pad(n) {
      return String(Math.max(0, n)).padStart(2, '0');
    }

    function tick() {
      if (!targetTime) return;
      const diffMs = targetTime.getTime() - Date.now();
      if (diffMs <= 0) {
        daysEl.textContent = '00';
        hoursEl.textContent = '00';
        minEl.textContent = '00';
        if (intervalId) clearInterval(intervalId);
        return;
      }
      const totalMinutes = Math.floor(diffMs / 60000);
      const days = Math.floor(totalMinutes / (60 * 24));
      const hours = Math.floor((totalMinutes % (60 * 24)) / 60);
      const minutes = totalMinutes % 60;
      daysEl.textContent = pad(days);
      hoursEl.textContent = pad(hours);
      minEl.textContent = pad(minutes);
    }

    function applyDrop(drop) {
      if (!drop || !drop.startTime) {
        card.hidden = true;
        return;
      }
      targetTime = new Date(drop.startTime);
      if (dropNameEl && drop.name) dropNameEl.textContent = drop.name;
      tick();
      intervalId = setInterval(tick, 1000);
    }

    async function loadDrop() {
      try {
        const params = new URLSearchParams(window.location.search);
        const shop = params.get('shop') || (window.Shopify && window.Shopify.shop) || '';
        const qs = new URLSearchParams();
        if (staticDropId) qs.set('dropId', staticDropId);
        if (shop) qs.set('shop', shop);
        const res = await fetch('/apps/hype/api/drop-status?' + qs.toString());
        if (!res.ok) {
          card.hidden = true;
          return;
        }
        const data = await res.json();
        applyDrop(data.drop);
      } catch (e) {
        console.error('[countdown] failed to load drop status', e);
        card.hidden = true;
      }
    }

    loadDrop();
  })();
</script>

{% schema %}
{
  "name": "Countdown Widget",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "drop_id",
      "label": "Drop ID",
      "info": "Copy the Drop ID from the Drops page in Vaultd. Leave empty to automatically use the live or next scheduled drop."
    },
    {
      "type": "select",
      "id": "design",
      "label": "Design",
      "options": [
        { "value": "minimal", "label": "Minimal / Elegant" },
        { "value": "bold", "label": "Bold / Vibrant" },
        { "value": "glass", "label": "Glassmorphism" }
      ],
      "default": "minimal"
    },
    {
      "type": "select",
      "id": "bold_color",
      "label": "Bold design color",
      "options": [
        { "value": "purple", "label": "Purple gradient" },
        { "value": "red", "label": "Red gradient" }
      ],
      "default": "purple",
      "visible_if": "{{ block.settings.design == \"bold\" }}"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Heading (minimal / bold designs)",
      "default": "Drop goes live in"
    },
    {
      "type": "text",
      "id": "eyebrow_glass",
      "label": "Heading (glassmorphism design)",
      "default": "Limited drop"
    },
    {
      "type": "text",
      "id": "fallback_drop_name",
      "label": "Fallback drop name (minimal design, shown until the real drop loads)",
      "default": "Drop"
    },
    {
      "type": "text",
      "id": "footer_bold",
      "label": "Footer text (bold design)",
      "default": "🔥 Don't miss out"
    },
    {
      "type": "text",
      "id": "footer_glass",
      "label": "Footer text (glassmorphism design)",
      "default": "Launching soon"
    }
  ]
}
{% endschema %}
